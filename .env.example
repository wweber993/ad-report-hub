# ==============================================================================
# AD Report Hub — Environment Configuration Example
# Copy this file to .env and configure your values.
# ==============================================================================

# ── Flask App ──────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090

# ── SSL (Optional — leave blank to run plain HTTP) ─────────────────
SSL_CERT=
SSL_KEY=

# ── Active Directory Data ─────────────────────────────────────────
# Directory where JSON reports are stored by the PowerShell collector
AD_DATA_DIR=data/ad

# ── Ingest API Security ───────────────────────────────────────────
# Secret token required by the PowerShell collector in X-API-Key header.
# REQUIRED — if empty the ingest endpoint will refuse all requests.
INGEST_TOKEN=your_secret_ingest_token_here

# ── Snapshot History ──────────────────────────────────────────────
# Number of days to retain historical snapshots. Older ones are auto-purged.
SNAPSHOT_RETENTION_DAYS=90

# ── Webhook / Alerting ────────────────────────────────────────────
# URL to POST alert payloads to (Slack, Teams, n8n, custom endpoint, etc.)
# Leave empty to disable alerting.
WEBHOOK_URL=

# Health Score threshold (0-100). Alert fires when score drops BELOW this value.
ALERT_HEALTH_THRESHOLD=60

# Locked account threshold. Alert fires when locked accounts EXCEED this count.
# Set to 0 to alert on ANY locked account.
ALERT_LOCKED_THRESHOLD=0

# Non-compliant percentage threshold (0-100).
# Alert fires when non-compliant users EXCEED this % of total.
ALERT_NONCOMPLIANT_PCT=30

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
