# ==============================================================================
# AD Report Hub — Environment Configuration Example
# Copy this file to .env and configure your variables.
# ==============================================================================

# Flask App Configuration
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production

# Server Host & Port
HOST=0.0.0.0
PORT=8090

# SSL Configuration (Optional)
SSL_CERT=
SSL_KEY=

# Ingest API Security Token (X-API-Key header)
# Set a secret token to protect /ad/api/ingest from unauthorized data posting.
INGEST_TOKEN=your_secret_ingest_token_here

# Active Directory Data Directory
AD_DATA_DIR=data/ad

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# SMTP Email Configuration (Optional - for User Invites & Password Reset)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=smtp_user
MAIL_PASSWORD=smtp_password
MAIL_DEFAULT_SENDER=adreporthub@company.com
